# ============================================
# TeamPilot Deployment Configuration
# Copy this file and modify as needed
# ============================================

# ── Database ──
POSTGRES_USER=teampilot
POSTGRES_PASSWORD=teampilot2026
POSTGRES_DB=teampilot
DATABASE_URL=postgresql+asyncpg://teampilot:teampilot2026@db:5432/teampilot

# ── JWT Authentication ──
# IMPORTANT: Change this to a random 64-char hex string in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Configuration (optional, can be set later in UI) ──
# Supports any OpenAI-compatible API: OpenAI, Claude, Deepseek, Ollama, etc.
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL_NAME=
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# ── CORS ──
# Frontend URL, change if deploying to a custom domain
CORS_ORIGINS=["http://localhost:5173","http://localhost"]

# ── Server Ports ──
BACKEND_PORT=8000
FRONTEND_PORT=80
