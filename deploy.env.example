# ============================================
# TeamPilot Deployment Configuration
# Copy this file to deploy.env and modify as needed
# ============================================

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=teampilot
POSTGRES_PASSWORD=teampilot2026
POSTGRES_DB=teampilot

# JWT Authentication
# IMPORTANT: This placeholder is replaced by deploy.sh automatically.
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AI_ENCRYPTION_KEY=change-me-to-a-random-64-char-hex-string-for-ai-secrets

# Bootstrap admin
# IMPORTANT: This placeholder is replaced by deploy.sh automatically.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-random-admin-password-in-production
ADMIN_EMAIL=admin@teampilot.com
ADMIN_FULL_NAME=System Administrator
SEED_DEMO_USERS=false

# AI Configuration (optional, can be set later in UI)
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL_NAME=
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# CORS
# Replace these with your real public URL(s) before exposing the app.
CORS_ORIGINS=["http://localhost","http://127.0.0.1"]

# Server Ports
BACKEND_PORT=8000
FRONTEND_PORT=80
