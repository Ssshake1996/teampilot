# Backend local development example
# Supported local development OS: Ubuntu 20.04.5+ / Windows 11+
# For production deployment, use deploy.env.example instead.
DATABASE_URL=sqlite+aiosqlite:///./teampilot.db

# JWT
JWT_SECRET_KEY=dev-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=90

# AI Encryption (for encrypting LLM API key at rest)
AI_ENCRYPTION_KEY=dev-ai-encryption-key

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Local bootstrap defaults
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
SEED_DEMO_USERS=true

# Email reports
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
REPORT_DEFAULT_RECIPIENTS=
REPORT_TIMEZONE=Asia/Shanghai
