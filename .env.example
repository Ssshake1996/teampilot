# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/project_mgmt

# JWT
JWT_SECRET_KEY=your-random-256-bit-hex-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Encryption (for encrypting LLM API key at rest)
AI_ENCRYPTION_KEY=your-random-256-bit-hex-encryption-key-here

# CORS
CORS_ORIGINS=["http://localhost:5173"]
